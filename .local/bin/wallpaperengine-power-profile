#!/usr/bin/env bash

last=""
default_wallpaper="/home/kerem/Wallpapers/japan-background-digital-art.jpg"

while true; do
  if command -v powerprofilesctl >/dev/null 2>&1; then
    profile="$(powerprofilesctl get 2>/dev/null || true)"
  else
    raw_profile="$(busctl get-property org.freedesktop.UPower.PowerProfiles /org/freedesktop/UPower/PowerProfiles org.freedesktop.UPower.PowerProfiles ActiveProfile 2>/dev/null || true)"
    profile="${raw_profile#*\"}"
    profile="${profile%\"*}"
  fi

  if [[ "$profile" != "$last" ]]; then
    last="$profile"

    case "$profile" in
      power-saver)
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller stop all \
          || ~/.config/noctalia/plugins/linux-wallpaperengine-controller/scripts/force-stop-engine.sh
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller setStaticWallpaperEnabled true
        if [[ -f "$default_wallpaper" ]]; then
          qs -c noctalia-shell ipc call wallpaper set "$default_wallpaper" all
        else
          qs -c noctalia-shell ipc call wallpaper random all
        fi
        ;;
      balanced)
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller setStaticWallpaperEnabled false
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller setPowerProfile balanced
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller reload
        ;;
      performance)
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller setStaticWallpaperEnabled false
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller setPowerProfile performance
        qs -c noctalia-shell ipc call plugin:linux-wallpaperengine-controller reload
        ;;
    esac
  fi

  sleep 5
done
